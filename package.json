{
  "name": "n8n-classroom-monorepo",
  "private": true,
  "workspaces": [
    "apps/bot",
    "apps/dashboard"
  ],
  "scripts": {
    "bot:dev": "npm --prefix apps/bot run dev",
    "bot:start": "npm --prefix apps/bot run start",
    "bot:typecheck": "npm --prefix apps/bot run typecheck",
    "dashboard:dev": "npm --prefix apps/dashboard run dev",
    "dashboard:build": "npm --prefix apps/dashboard run build",
    "classroom:start": "node scripts/start_local_classroom.cjs",
    "verify": "npm run bot:typecheck"
  }
}
